    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "argon2": "^0.45.0",
    "clsx": "^2.1.1",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.25.0",
    "mongodb": "^7.5.0",
    "mongoose": "^9.7.4",
    "nanoid": "^6.0.0",
    "next": "16.2.10",
    "next-auth": "5.0.0-beta.31",
    "next-themes": "^0.4.6",
