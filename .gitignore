# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.next-e2e/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local infrastructure and generated email
/.local/
/.artifacts/
/backups/
*.backup
*.dump

# browser and integration test output
/test-results/
/playwright-report/
/blob-report/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
