# Copy this file to .env for local development. Every value containing
# "replace-me", "change-me", or "ChangeMe" is a placeholder, not a real secret.

# Compose and local ports
COMPOSE_PROJECT_NAME=dastack-local
MONGO_PORT=27017
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
CADDY_HTTP_PORT=8080
NGINX_HTTP_PORT=8081
CADVISOR_PORT=8082
PROMETHEUS_PORT=9090

# MongoDB (single-node rs0 replica set for transaction support)
MONGO_ROOT_USERNAME=dastack_root
MONGO_ROOT_PASSWORD=change-me-local-mongo-root
MONGO_APP_USERNAME=dastack
MONGO_APP_PASSWORD=change-me-local-mongo-app
# Must use base64 characters only. Generate one with: openssl rand -base64 48
MONGO_REPLICA_KEY=ChangeMeLocalReplicaKey32CharactersMinimum
MONGODB_DB=dastack
MONGODB_URI=mongodb://dastack:change-me-local-mongo-app@127.0.0.1:27017/dastack?authSource=dastack&replicaSet=rs0&directConnection=true
MONGODB_INTERNAL_URI=mongodb://dastack:change-me-local-mongo-app@mongo:27017/dastack?authSource=dastack&replicaSet=rs0&directConnection=true
# Optional outside local development: privileged lifecycle URI used only by
# the test wrapper to create a scoped user and drop its disposable database.
E2E_MONGODB_URI=

# Redis
REDIS_PASSWORD=change-me-local-redis
REDIS_URL=redis://:change-me-local-redis@127.0.0.1:6379/0
REDIS_INTERNAL_URL=redis://:change-me-local-redis@redis:6379/0
JOB_QUEUE_PREFIX=dastack-local

# Application and Auth.js
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
AUTH_SECRET=replace-me-with-at-least-32-random-bytes
TRUST_PROXY=false
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Email. The file adapter is development-only and MUST NOT be used in production.
EMAIL_ADAPTER=file
EMAIL_DEV_DIR=.local/emails
EMAIL_FROM="DaStack Local <no-reply@example.test>"
EMAIL_REPLY_TO=support@example.test
RESEND_API_KEY=

# Application data encryption. Generate independent 32-byte base64 values.
DATA_ENCRYPTION_KEY=replace-me-with-32-random-bytes-base64
CREDENTIAL_ENCRYPTION_KEY=replace-me-with-another-32-random-bytes-base64

# Stripe is deferred beyond Phase 1. Placeholders are reserved for later use.
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=sk_test_replace-me-deferred
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace-me-deferred
STRIPE_WEBHOOK_SECRET=whsec_replace-me-deferred

# MinIO/S3 (local-only root credentials; use scoped IAM credentials in production)
MINIO_ROOT_USER=dastack-local
MINIO_ROOT_PASSWORD=change-me-local-minio-password
MINIO_BUCKET=dastack
S3_ENDPOINT=http://127.0.0.1:9000
S3_INTERNAL_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=dastack
S3_ACCESS_KEY_ID=dastack-local
S3_SECRET_ACCESS_KEY=change-me-local-minio-password
S3_FORCE_PATH_STYLE=true

# Worker/control-plane security. `pnpm worker:token` creates a one-time token and
# digest. Store only the digest here; deliver the token to the agent out of band.
WORKER_CONTROL_PLANE_URL=http://localhost:3000
WORKER_ALLOW_INSECURE_HTTP=true
WORKER_ENROLLMENT_TOKEN_DIGEST=
WORKER_SYSTEM_ACTOR_ID=
WORKER_SYSTEM_ORGANIZATION_ID=
WORKER_CONTROL_SIGNING_KEY_ID=
WORKER_CONTROL_SIGNING_PRIVATE_KEY=
WORKER_HEARTBEAT_INTERVAL_SECONDS=30
WORKER_CREDENTIAL_TTL_SECONDS=86400
WORKER_REQUEST_MAX_SKEW_SECONDS=60
WORKER_NONCE_TTL_SECONDS=300
WORKER_DISCONNECT_AFTER_SECONDS=90
WORKER_RECONCILIATION_BATCH_SIZE=100
JOB_RUNNER_RECONCILIATION_INTERVAL_MS=60000
JOB_RUNNER_WORKER_CHECK_INTERVAL_MS=30000
JOB_RUNNER_HEALTH_PORT=9465
